# SSV Staking App - Environment Configuration
# Edit JSON array here: https://jsoneditoronline.org

# VITE_SSV_NETWORKS - Array of network configurations
# Each network object contains:
# - networkId: Chain ID (560048 for Hoodi, 1 for Mainnet)
# - chainName: Display name of the network
# - rpcUrl: RPC endpoint URL
# - apiVersion: API version (v4)
# - apiNetwork: Network identifier for API (hoodi, mainnet)
# - api: Base API URL without version/network suffix
# - blockExplorerName: Name of block explorer
# - blockExplorerUrl: Block explorer base URL
# - tokenAddress: SSV token contract address
# - cTokenAddress: cSSV token contract address (cluster SSV)
# - setterContractAddress: Staking contract address
# - getterContractAddress: Views contract address
# - faucetUrl: Faucet URL (null if not available)
# - dvtUrl: DVT application URL
# - abiType: ABI type to use ("stage" | "hoodi" | "mainnet")

# Geo IP API keys for country restriction (https://ipgeolocation.io, https://ipregistry.co, https://bigdatacloud.com)
VITE_IPGEO_API_KEY=your_ipgeo_api_key
VITE_IPREGISTRY_KEY=your_ipregistry_key
VITE_BIGDATACLOUD_KEY=your_bigdatacloud_key

# Example for Stage environment (Hoodi Stage only):
VITE_SSV_NETWORKS='[{"networkId":560048,"chainName":"Hoodi","rpcUrl":"https://ethereum-hoodi-rpc.publicnode.com/YOUR_RPC_KEY","apiVersion":"v4","apiNetwork":"hoodi","api":"https://api.stage.ops.ssvlabsinternal.com/api","blockExplorerName":"Hoodi Explorer","blockExplorerUrl":"https://hoodi.etherscan.io","tokenAddress":"0x746c33ccc28b1363c35c09badaf41b2ffa7e6d56","cTokenAddress":"0xd15Dbea3e279042e2EaB4f02D49331Dc37B5b7E6","setterContractAddress":"0x384AC2c8AF4Df1faD7E20F15064B2C2917fAa7a3","getterContractAddress":"0x92c71f0A9823789f72BAEBB2BFE39e897bDd26bd","faucetUrl":"https://faucet.stage.ssv.network/","dvtUrl":"https://app.stage.ssv.network/","abiType":"stage"}]'
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
